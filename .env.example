# Board webhook receiver (issue #51) — server-side only, never commit real values.
# The GitHub App's webhook secret (same value the old worker's
# webhook-secret.txt held) — used to verify incoming webhook signatures.
BOARD_WEBHOOK_SECRET=

# A CLASSIC GitHub PAT (not fine-grained) with `repo` + `project` scopes.
# Dedicated to this endpoint only — do not reuse the voice-feedback
# pipeline's token (see issue #43) or Jose's local gh CLI auth, so a
# compromise of one credential doesn't extend to the others.
BOARD_WEBHOOK_GITHUB_TOKEN=

# Optional — Supabase service-role key for the vcp-ops project
# (qaorlbgrkpldcatyntlw), used for fire-and-forget pipeline event capture
# (issue #41). Missing key just means events aren't logged; never blocks
# the merge guard itself.
SUPABASE_SERVICE_KEY=
